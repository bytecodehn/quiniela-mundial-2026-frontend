# Base URL del backend Go (montado en la raíz, SIN /api/v1).
# Dev server LAN: http://192.168.244.128:8888
NEXT_PUBLIC_API_URL=http://localhost:8888

# "true" = renderiza con fixtures mock locales en vez de llamar a la API.
# Integración FE↔BE COMPLETA (F1–F6): el default es backend real (false).
# Poné "true" para modo offline/demo (sin backend). La suite e2e setea
# USE_MOCKS=true en su propio webServer, así que sigue corriendo con mocks.
NEXT_PUBLIC_USE_MOCKS=false

# Overrides de mock por-módulo (opcionales): NEXT_PUBLIC_USE_MOCKS_AUTH,
# _TOURNAMENT, _GROUPS, _LEADERBOARD, _PREDICTIONS, _ADMIN. "true"/"false";
# si no se definen, caen al global de arriba. Útiles para forzar un módulo a
# mock/real sin tocar el resto.

# Canonical URL of the deployed site. Used by Next metadata + Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" to log analytics events to the console (development only).
# When a real provider (PostHog/Mixpanel/GA) is plugged in via setAnalyticsProvider,
# this flag becomes irrelevant.
NEXT_PUBLIC_ANALYTICS_DEBUG=true

# VAPID public key for Web Push. Sin esta clave (y el backend que envía pushes
# con la private key correspondiente) solo funcionan notificaciones locales,
# no recordatorios automáticos de deadlines. Generar con `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
