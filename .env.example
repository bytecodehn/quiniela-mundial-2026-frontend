# Base URL for the backend API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Set to "true" to render pages with local mock fixtures instead of calling the API.
# Useful while the backend is not yet available. Leave empty / unset in production.
NEXT_PUBLIC_USE_MOCKS=true

# Canonical URL of the deployed site. Used by Next metadata + Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" to log analytics events to the console (development only).
# When a real provider (PostHog/Mixpanel/GA) is plugged in via setAnalyticsProvider,
# this flag becomes irrelevant.
NEXT_PUBLIC_ANALYTICS_DEBUG=true
